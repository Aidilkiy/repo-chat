# server/.env — copy this to server/.env and fill in real values
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Optional: raises GitHub API rate limits for ingesting larger repos
GITHUB_TOKEN=
PORT=8787
DB_PATH=repo-chat.sqlite
