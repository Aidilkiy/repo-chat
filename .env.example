# Copy the relevant lines into services/ingest-service/.env and services/query-service/.env
# Get a free Gemini key at https://aistudio.google.com/apikey

# --- ingest-service/.env ---
GEMINI_API_KEY=your-gemini-key-here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Optional: raises GitHub API rate limits for ingesting larger repos (recommended, since
# raw file fetches now go through the same rate-limited GitHub REST API as everything else)
GITHUB_TOKEN=
PORT=8788
DB_PATH=../repo-chat.sqlite

# --- query-service/.env ---
# GEMINI_API_KEY=your-gemini-key-here (same key as above)
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# PORT=8789
# DB_PATH=../repo-chat.sqlite
